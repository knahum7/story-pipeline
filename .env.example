# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# OpenAI (fallback when Claude content filter triggers)
OPENAI_API_KEY="your-openai-api-key-here"

# Google Cloud Vision (for image/OCR text extraction)
# Paste the FULL JSON content of your service account key file
GOOGLE_CLOUD_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Supabase (database for pipeline storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# fal.ai (image generation)
FAL_KEY="your-fal-ai-api-key-here"

